{
	"name": "bedrock-vscode-chat",
	"publisher": "arifum",
	"displayName": "AWS Bedrock Provider for GitHub Copilot Chat",
	"description": "Native AWS Bedrock integration for GitHub Copilot Chat. Brings Claude, Llama, and Mistral models into your editor with streaming, function calling, and vision support across 14 regions.",
	"icon": "assets/logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/aristide1997/bedrock-vscode-chat"
	},
	"version": "0.0.2",
	"engines": {
		"vscode": "^1.104.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"galleryBanner": {
		"color": "#100f11",
		"theme": "dark"
	},
	"badges": [
		{
			"url": "https://img.shields.io/github/stars/aristide1997/bedrock-vscode-chat?style=social",
			"description": "Star on Github",
			"href": "https://github.com/aristide1997/bedrock-vscode-chat"
		}
	],
	"homepage": "https://aws.amazon.com/bedrock/",
	"bugs": {
		"url": "https://github.com/aristide1997/bedrock-vscode-chat/issues"
	},
	"license": "MIT",
	"contributes": {
		"configuration": {
			"title": "AWS Bedrock Chat",
			"properties": {
				"bedrockChat.thinking.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable extended thinking for supported Claude models.",
					"scope": "resource"
				},
				"bedrockChat.thinking.budgetTokens": {
					"type": "number",
					"default": 20000,
					"minimum": 1024,
					"description": "Tokens allocated for thinking. Minimum 1024. Default is 20% of max output tokens.",
					"scope": "resource"
				},
				"bedrockChat.thinking.effort": {
					"type": "string",
					"default": "max",
					"enum": ["max", "high", "medium", "low"],
					"enumDescriptions": [
						"Maximum thinking effort.",
						"High effort - thorough reasoning.",
						"Balanced approach.",
						"Most efficient."
					],
					"description": "Thinking effort level for Claude models.",
					"scope": "resource"
				},
				"bedrockChat.context1M.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable 1M context model variant for Claude Opus 4.6+. Context capped to contextLimit.",
					"scope": "resource"
				},
				"bedrockChat.contextLimit": {
					"type": "number",
					"default": 400000,
					"minimum": 200000,
					"maximum": 1000000,
					"description": "Max context window (tokens). 1M model used but input capped here. Default 400k.",
					"scope": "resource"
				},
				"bedrockChat.maxOutputTokens": {
					"type": "number",
					"default": 64000,
					"minimum": 4096,
					"maximum": 128000,
					"description": "Max output tokens for Claude models when thinking is enabled.",
					"scope": "resource"
				}
			}
		},
		"languageModelChatProviders": [
			{
				"vendor": "bedrock",
				"displayName": "AWS Bedrock",
				"managementCommand": "bedrock.manage"
			}
		],
		"commands": [
			{
				"command": "bedrock.manage",
				"title": "Manage AWS Bedrock Provider"
			}
		]
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"download-api": "dts dev",
		"postdownload-api": "dts main",
		"postinstall": "npm run download-api",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"format": "prettier --write .",
		"watch": "tsc -watch -p ./",
		"test": "npm run compile && vscode-test"
	},
	"dependencies": {
		"@aws-sdk/client-bedrock": "^3.716.0",
		"@aws-sdk/client-bedrock-runtime": "^3.716.0",
		"@aws-sdk/credential-providers": "^3.901.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"@types/vscode": "^1.103.0",
		"@vscode/dts": "^0.4.1",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"dotenv": "^17.2.3",
		"eslint": "^9.13.0",
		"prettier": "^3.1.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}
